{
    "manifest_version": 3,
    "name": "YouTube Premium Plus",
    "version": "1.1.0",
    "description": "Enhance YouTube UI and add features globally.",
    "permissions": [
        "storage",
        "scripting",
        "tabs",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>",
        "*://www.youtube.com/*",
        "*://returnyoutubedislikeapi.com/*",
        "*://sponsor.ajay.app/*"
    ],
    "icons": {
        "16": "src/assets/icon.png",
        "48": "src/assets/icon.png",
        "128": "src/assets/icon.png"
    },
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "src/assets/icon.png",
            "48": "src/assets/icon.png",
            "128": "src/assets/icon.png"
        }
    },
    "background": {
        "service_worker": "src/background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "src/content/styles.css"
            ],
            "run_at": "document_idle",
            "all_frames": true,
            "js": [
                "dist/content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "src/assets/*",
                "src/inject/*",
                "src/content/themes/*.css",
                "src/content/features/**/*.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}