{
    "manifest_version": 3,
    "name": "YouTube Premium Plus",
    "version": "1.1.0",
    "default_locale": "en",
    "description": "Enhance YouTube UI and add features globally.",
    "permissions": [
        "storage",
        "alarms",
        "tabs",
        "identity",
        "contextMenus"
    ],
    "host_permissions": [
        "*://www.youtube.com/*",
        "*://returnyoutubedislikeapi.com/*",
        "*://sponsor.ajay.app/*",
        "<all_urls>"
    ],
    "icons": {
        "16": "src/assets/icon-128.png",
        "48": "src/assets/icon-128.png",
        "128": "src/assets/icon-128.png"
    },
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "src/assets/icon-128.png",
            "48": "src/assets/icon-128.png",
            "128": "src/assets/icon-128.png"
        }
    },
    "background": {
        "service_worker": "src/background/service-worker.js",
        "type": "module"
    },
    "options_page": "src/options/options.html",
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "css": [
                "dist/style.css",
                "src/content/styles.css",
                "src/content/features/global/layout/header-nav.css",
                "src/content/features/pages/home/cards.css",
                "src/content/features/player/player.css"
            ],
            "run_at": "document_end",
            "all_frames": false,
            "js": [
                "dist/content.js"
            ]
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "exclude_matches": [
                "*://www.youtube.com/*"
            ],
            "run_at": "document_idle",
            "all_frames": true,
            "js": [
                "dist/global-bar-external.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "src/assets/*",
                "src/inject/*",
                "src/content/themes/*.css",
                "src/content/features/**/*.css"
            ],
            "matches": [
                "*://www.youtube.com/*",
                "<all_urls>"
            ]
        }
    ],
    "oauth2": {
        "client_id": "YOUR_GOOGLE_CLOUD_OAUTH_CLIENT_ID_HERE.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/drive.appdata"
        ]
    }
}